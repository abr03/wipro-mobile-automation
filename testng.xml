<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="Wipro Assignment Suite">
    <listeners>
        <listener class-name="app.wiproAssignment.com.listeners.TestListener"/>
    </listeners>

    <parameter name="platform" value="ios"/>
    <parameter name="runMode" value="local"/>

    <test name="Taqelah Tests">
        <groups>
            <run>
                <include name="Smoke"/>
                <include name="Regression"/>
            </run>
        </groups>
        <classes>
            <class name="testCases.SmokeTest"/>

            <class name="testCases.RegressionTest"/>


        </classes>
    </test>

</suite>